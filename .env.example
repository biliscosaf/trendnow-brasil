# Database
DATABASE_URL="postgresql://user:password@localhost:5432/trendnow_brasil"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET="your-secret-key-min-64-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-64-chars"

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY="your-32-byte-hex-key"

# Mercado Pago
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-your-public-key"
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-your-access-token"
MP_WEBHOOK_SECRET="your-webhook-secret"

# Email (SendGrid ou Mailgun)
SENDGRID_API_KEY="SG.your-api-key"
SENDGRID_FROM_EMAIL="noreply@trendnow.com.br"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://your-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Monitoramento
SENTRY_AUTH_TOKEN="your-sentry-token"
SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"

# Analytics (opcional)
NEXT_PUBLIC_GA_ID="UA-your-ga-id"

# Environment
NODE_ENV="development"
VERCEL_ENV="development"
