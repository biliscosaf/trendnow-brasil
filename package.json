{
  "name": "trendnow-brasil",
  "version": "0.1.0",
  "private": true,
  "description": "Tudo que está em alta com melhor preço",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "security": "npm audit --audit-level=moderate && npx snyk test",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "import:products": "tsx scripts/import-products.ts"
  },
  "dependencies": {
    "next": "14.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "typescript": "5.3.3",
    "zustand": "4.4.7",
    "framer-motion": "10.16.16",
    "tailwindcss": "3.4.1",
    "next-auth": "4.24.10",
    "jsonwebtoken": "9.1.2",
    "bcrypt": "5.1.1",
    "zod": "3.22.4",
    "isomorphic-dompurify": "2.3.0",
    "drizzle-orm": "0.29.1",
    "pg": "8.11.3",
    "axios": "1.6.5",
    "@upstash/ratelimit": "1.1.0",
    "@upstash/redis": "1.25.4",
    "mercadopago": "2.1.0",
    "next-image-export-optimizer": "1.18.1",
    "csv-parse": "5.5.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "20.10.6",
    "@types/react": "18.2.46",
    "@types/react-dom": "18.2.18",
    "@types/bcrypt": "5.0.2",
    "@types/uuid": "9.0.7",
    "autoprefixer": "10.4.16",
    "drizzle-kit": "0.20.13",
    "postcss": "8.4.32",
    "prettier": "3.1.1",
    "vitest": "1.1.0",
    "playwright": "1.40.1",
    "@testing-library/react": "14.1.2",
    "@testing-library/jest-dom": "6.1.5",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "tsx": "4.7.0"
  },
  "engines": {
    "node": "18.17.0 || 19.x || 20.x"
  }
}
